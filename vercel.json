{
  "rewrites": [
    { "source": "/__/auth/:path*", "destination": "https://sckakomonam-a46eb.firebaseapp.com/__/auth/:path*" }
  ],
  "headers": [
    { "source": "/sw.js",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }] },
    { "source": "/index.html",
      "headers": [{ "key": "Cache-Control", "value": "no-cache" }] },
