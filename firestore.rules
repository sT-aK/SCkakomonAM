// Firestore セキュリティルール（Firebase コンソール > Firestore > ルール に貼って公開する）
// このファイルはドキュメント用のコピー。デプロイはコンソールから行う。
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 自分の users/{uid} 配下のみ読み書き可（sync/main と images/{qid} を含む）。他は全拒否。
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
